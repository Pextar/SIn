# SIn Authentication Server — environment configuration
# Copy to /etc/sin/config.env on the Pi and fill in your values.

# Base URL the Pi will be reachable at from the browser (no trailing slash).
# Use your Pi's hostname or local IP.
SIN_BASE=http://raspberrypi.local:8080

# Address and port the server binds to.
SIN_ADDR=0.0.0.0:8080

# Secret used to sign challenges (generate with: sin secret).
# Run once: sin secret  →  copy the hex output here.
SIN_SECRET=

# Secret used to sign session cookies (generate with: sin secret).
SIN_SESSION_SECRET=

# Session lifetime in seconds (default: 3600 = 1 hour).
SIN_SESSION_TTL=3600

# Path to the allowlist JSON file (managed by the sin CLI).
SIN_ALLOWLIST=/var/lib/sin/allowlist.json

# Path to the built web assets (PWA signer).
SIN_WEB_DIR=/opt/sin/web/dist
